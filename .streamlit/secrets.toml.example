# Streamlit Secrets Template
# Instructions: 
# 1. DO NOT rename this to secrets.toml locally (it's in .gitignore anyway).
# 2. Copy the content below into the "Secrets" field in your Streamlit Cloud dashboard.

GEMINI_API_KEY = "your_actual_api_key_here"

# Optional: Add secondary keys for rotation if needed
# GEMINI_API_KEY_2 = "your_second_key_here"
# GEMINI_API_KEY_3 = "your_third_key_here"

# Database Configuration
DUCKDB_PATH = "data/Database_Data.duckdb"
